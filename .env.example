# Pinterest (Vite dev server only — see vite-plugin-pinterest-api.js)
# Copy to .env and fill in values from https://developers.pinterest.com/apps/

# Used by the dev middleware for token exchange (never expose in static hosting).
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Exposed to the browser for OAuth authorize URL and callback handling.
VITE_PINTEREST_APP_ID=
VITE_PINTEREST_REDIRECT_URI=http://localhost:5173/pinterest/oauth/callback

# Optional overrides (defaults are boards:read,pins:read)
# VITE_PINTEREST_OAUTH_SCOPE=boards:read,pins:read,boards:read_secret,pins:read_secret
# VITE_PINTEREST_CC_SCOPE=boards:read,pins:read
